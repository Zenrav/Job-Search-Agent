# ═══════════════════════════════════════════════════════════════
#  Job Search Agent — Environment Variables
#  Copy this file: cp .env.example .env
#  Then fill in your actual values. Never commit .env to git.
# ═══════════════════════════════════════════════════════════════


# ── Anthropic ────────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Used by Docker Compose to initialise the Postgres container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=job_agent
POSTGRES_PORT=5432

# Full connection URL used by SQLAlchemy / asyncpg inside the app
# Inside Docker Compose, hostname = service name ("postgres")
# For local dev outside Docker, use "localhost"
DATABASE_URL=postgresql+asyncpg://postgres:your_postgres_password@postgres:5432/job_agent
DATABASE_URL_LOCAL=postgresql+asyncpg://postgres:your_postgres_password@localhost:5432/job_agent


# ── FastAPI app ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# "development" or "production"
APP_ENV=development
# Any long random string — used for signing JWT tokens if you add auth
SECRET_KEY=change_this_to_a_long_random_string


# ── MCP server ports ─────────────────────────────────────────────────────────
# Each MCP server runs as a separate service
RESUME_MCP_PORT=8001
JD_MCP_PORT=8002
TRACKER_MCP_PORT=8003

# Internal URLs used by the agent to reach MCP servers
# Inside Docker Compose, use service names as hostnames
RESUME_MCP_URL=http://resume-store:8001
JD_MCP_URL=http://jd-analyzer:8002
TRACKER_MCP_URL=http://tracker:8003

# For local dev (running services directly, not via Docker)
RESUME_MCP_URL_LOCAL=http://localhost:8001
JD_MCP_URL_LOCAL=http://localhost:8002
TRACKER_MCP_URL_LOCAL=http://localhost:8003


# ── Email — SendGrid (Phase 5) ───────────────────────────────────────────────
# Sign up at: https://sendgrid.com/ (free tier: 100 emails/day)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=you@yourdomain.com
FROM_NAME=Job Search Agent


# ── Email — Raw SMTP alternative (if not using SendGrid) ─────────────────────
# Example values below are for Gmail. Enable "App Passwords" in your Google account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your_gmail_app_password


# ── Job Discovery APIs (Phase 3) ─────────────────────────────────────────────
# RapidAPI JSearch — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAPIDAPI_HOST=jsearch.p.rapidapi.com

# LinkedIn API (optional — requires LinkedIn partner access)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=


# ── Scheduler ────────────────────────────────────────────────────────────────
# Number of days after sending before a follow-up is suggested
FOLLOWUP_DAYS_THRESHOLD=7
# Time to run the daily check (24h format, server local time)
SCHEDULER_RUN_HOUR=9
SCHEDULER_RUN_MINUTE=0


# ── Frontend / CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO